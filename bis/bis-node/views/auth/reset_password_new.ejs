<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Set New Password - Bacolod BIS</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
  <link rel="stylesheet" href="/style.css">
</head>
<body class="auth-body">
  <div class="auth-card">
    <div class="auth-logo"><img src="/bacolod.png" alt="Bacolod BIS"></div>
    <h2 class="auth-title">Set New Password</h2>
    <p class="auth-sub">Choose a strong password (min. 8 characters).</p>
    <%- include('../partials/flash') %>
    <form action="/forgot-password/reset" method="POST" class="auth-form">
      <div class="auth-field">
        <label>New Password</label>
        <div class="auth-input-wrap"><i class="fas fa-lock"></i>
          <input type="password" name="new_password" placeholder="Min. 8 characters" required autofocus>
        </div>
      </div>
      <div class="auth-field">
        <label>Confirm Password</label>
        <div class="auth-input-wrap"><i class="fas fa-lock"></i>
          <input type="password" name="confirm_password" placeholder="Repeat password" required>
        </div>
      </div>
      <button type="submit" class="auth-btn">Save Password <i class="fas fa-save"></i></button>
    </form>
  </div>
</body>
</html>
