<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Clearances - Bacolod BIS</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
  <link rel="stylesheet" href="/style.css">
  <style>
    .clr-badge{display:inline-flex;align-items:center;gap:5px;font-size:11.5px;font-weight:600;padding:4px 10px;border-radius:100px;}
    .clr-badge--pending{background:#fff8f0;color:#b7600a;border:1px solid #fde8c8;}
    .clr-badge--approved{background:#f0faf6;color:#1a7a55;border:1px solid #c3e8d8;}
    .clr-badge--rejected{background:#fff0f1;color:#c0392b;border:1px solid #fad4d4;}
    .clr-badge--released{background:#eef0fb;color:#1d2448;border:1px solid #d0d8f5;}
    .clr-empty{text-align:center;padding:48px 20px;color:#9aa0b4;}
    .clr-empty i{font-size:40px;display:block;margin-bottom:12px;color:#d0d5e8;}
    .clr-no-hh{background:#fff8f0;border:1px solid #fde8c8;border-radius:10px;padding:14px 16px;font-size:13px;color:#b7600a;display:flex;gap:10px;align-items:flex-start;margin-bottom:20px;}
  </style>
</head>
<body class="db-body">
  <% const role = 'resident'; const active = 'clearance'; %>
  <%- include('../../partials/sidebar', { role, active }) %>
  <div class="db-main">
    <%- include('../../partials/topbar', { pageTitle: 'My Clearances' }) %>
    <div class="db-welcome">
      <div>
        <h2>Hello, <%= session.fullName || 'Resident' %> 👋</h2>
        <p>Barangay Bacolod, Bato, Camarines Sur — Barangay Information System</p>
      </div>
      <div class="db-welcome-icon"><i class="fas fa-users"></i></div>
    </div>
    <div class="db-content">
      <%- include('../../partials/flash') %>

      <% if (!members || !members.length) { %>
        <div class="clr-no-hh">
          <i class="fas fa-exclamation-triangle" style="margin-top:2px;flex-shrink:0;"></i>
          <div>Your account is not linked to a household. Please contact the barangay office.</div>
        </div>
      <% } %>

      <div class="db-toolbar">
        <div class="db-search-wrap">
          <i class="fas fa-search"></i>
          <input type="text" placeholder="Search requests..." id="searchInput" oninput="filterRequests()">
        </div>
        <div class="db-toolbar-actions">
          <% if (members && members.length) { %>
            <button class="db-btn db-btn--primary" onclick="document.getElementById('newModal').classList.add('active')">
              <i class="fas fa-plus"></i> New Request
            </button>
          <% } %>
        </div>
      </div>

      <div class="db-table-wrap">
        <table class="db-table" id="requestsTable">
          <thead><tr><th>#</th><th>For</th><th>Document Type</th><th>Purpose</th><th>Date Filed</th><th>Est. Release</th><th>Status</th><th>Action</th></tr></thead>
          <tbody>
            <% if (!requests || !requests.length) { %>
              <tr><td colspan="8"><div class="clr-empty"><i class="fas fa-file-alt"></i><p>No requests yet. Click <strong>New Request</strong> to get started.</p></div></td></tr>
            <% } else { %>
              <% const statusMap = { pending:['clr-badge--pending','fa-clock','Pending'], approved:['clr-badge--approved','fa-check-circle','Approved'], rejected:['clr-badge--rejected','fa-times-circle','Rejected'], released:['clr-badge--released','fa-box-open','Released'] }; %>
              <% requests.forEach(r => {
                const [badgeClass, icon, label] = statusMap[r.status] || statusMap.pending;
                const filed   = new Date(r.created_at).toLocaleDateString('en-US',{month:'short',day:'2-digit',year:'numeric'});
                const release = r.est_release_date ? new Date(r.est_release_date).toLocaleDateString('en-US',{month:'short',day:'2-digit',year:'numeric'}) : '—';
              %>
                <tr>
                  <td><strong>#<%= String(r.id).padStart(3,'0') %></strong></td>
                  <td>
                    <div style="font-size:13px;font-weight:600;color:#1a1d2e;"><%= r.for_member %></div>
                    <div style="font-size:11px;color:#9aa0b4;"><%= r.member_relationship || '' %></div>
                  </td>
                  <td><%= r.document_type %></td>
                  <td><%= r.purpose %></td>
                  <td><%= filed %></td>
                  <td><%= release %></td>
                  <td><span class="clr-badge <%= badgeClass %>"><i class="fas <%= icon %>"></i> <%= label %></span></td>
                  <td>
                    <% if (r.status === 'pending') { %>
                      <button type="button" class="db-icon-btn db-icon-btn--del" title="Cancel"
                        onclick="confirmCancel(<%= r.id %>, '<%= r.document_type.replace(/'/g,"\\'") %>')">
                        <i class="fas fa-times"></i>
                      </button>
                    <% } else { %>
                      <button class="db-icon-btn db-icon-btn--view" title="View" disabled><i class="fas fa-eye"></i></button>
                    <% } %>
                  </td>
                </tr>
              <% }); %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Cancel Modal -->
  <div class="db-modal-overlay" id="cancelModal">
    <div class="db-modal" style="max-width:400px;">
      <div class="db-modal-header" style="background:#fff0f1;border-bottom:1px solid #fad4d4;">
        <h3 style="color:#c0392b;font-size:14px;display:flex;align-items:center;gap:8px;"><i class="fas fa-exclamation-triangle"></i> Cancel Request</h3>
        <button class="db-modal-close" onclick="document.getElementById('cancelModal').classList.remove('active')"><i class="fas fa-times"></i></button>
      </div>
      <div class="db-modal-body" style="padding:24px;">
        <p style="font-size:13.5px;color:#4a5068;margin:0 0 6px;">Are you sure you want to cancel this request?</p>
        <p id="cancelDocType" style="font-size:14px;font-weight:700;color:#1a1d2e;margin:0 0 16px;"></p>
        <p style="font-size:12.5px;color:#9aa0b4;margin:0;">This action cannot be undone.</p>
      </div>
      <div class="db-modal-footer" style="gap:10px;">
        <button class="db-btn db-btn--outline" onclick="document.getElementById('cancelModal').classList.remove('active')" style="flex:1;">Keep Request</button>
        <form id="cancelForm" method="POST" style="flex:1;">
          <button type="submit" class="db-btn db-btn--danger" style="width:100%;justify-content:center;"><i class="fas fa-times"></i> Yes, Cancel It</button>
        </form>
      </div>
    </div>
  </div>

  <!-- New Request Modal -->
  <div class="db-modal-overlay" id="newModal">
    <div class="db-modal" style="max-width:560px;border-radius:16px;overflow:hidden;">
      <div style="background:linear-gradient(135deg,#1d2448,#2e3a6e);padding:22px 28px;display:flex;align-items:center;justify-content:space-between;">
        <div style="display:flex;align-items:center;gap:14px;">
          <div style="width:42px;height:42px;border-radius:10px;background:rgba(255,255,255,.15);display:flex;align-items:center;justify-content:center;font-size:18px;color:#fff;"><i class="fas fa-file-alt"></i></div>
          <div>
            <h3 style="color:#fff;font-size:16px;font-weight:700;margin:0 0 2px;">New Document Request</h3>
            <p style="color:rgba(255,255,255,.65);font-size:12px;margin:0;">Fill in the details below</p>
          </div>
        </div>
        <button style="background:rgba(255,255,255,.12);border:none;color:#fff;width:32px;height:32px;border-radius:50%;cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center;" onclick="document.getElementById('newModal').classList.remove('active')"><i class="fas fa-times"></i></button>
      </div>
      <form action="/resident/clearance/store" method="POST">
        <div style="padding:24px 28px;background:#f9fafb;max-height:72vh;overflow-y:auto;">
          <!-- Who is this for -->
          <div style="margin-bottom:22px;">
            <div style="font-size:11px;font-weight:700;color:#9aa0b4;text-transform:uppercase;letter-spacing:.6px;margin-bottom:10px;display:flex;align-items:center;gap:6px;"><i class="fas fa-user" style="color:#1d2448;"></i> Who is this document for?</div>
            <% if (!members || !members.length) { %>
              <p style="font-size:12.5px;color:#b7600a;background:#fff8f0;padding:10px 14px;border-radius:8px;border:1px solid #fde8c8;"><i class="fas fa-exclamation-triangle"></i> No household members found.</p>
            <% } else { %>
              <div style="display:flex;flex-wrap:wrap;gap:8px;" id="memberPills">
                <% members.forEach((m, i) => { %>
                  <label style="display:flex;align-items:center;gap:10px;padding:10px 14px;border:2px solid <%= i===0?'#1d2448':'#e2e5ef' %>;border-radius:12px;cursor:pointer;background:<%= i===0?'#1d2448':'#fff' %>;transition:all .2s;font-family:'Poppins',sans-serif;"
                    onclick="selectMember(this,'<%= m.name.replace(/'/g,"\\'") %>','<%= m.relationship.replace(/'/g,"\\'") %>')">
                    <input type="radio" name="_member_ui" value="<%= m.name %>" <%= i===0?'checked':'' %> style="display:none;">
                    <div style="width:32px;height:32px;border-radius:50%;background:<%= i===0?'rgba(255,255,255,.2)':'#eef0fb' %>;color:<%= i===0?'#fff':'#1d2448' %>;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;flex-shrink:0;"><%= m.name[0].toUpperCase() %></div>
                    <div>
                      <div style="font-size:12.5px;font-weight:600;color:<%= i===0?'#fff':'#1a1d2e' %>;line-height:1.3;"><%= m.name %></div>
                      <div style="font-size:11px;color:<%= i===0?'rgba(255,255,255,.7)':'#9aa0b4' %>;"><%= m.relationship %></div>
                    </div>
                  </label>
                <% }); %>
              </div>
              <input type="hidden" name="for_member" id="forMember" value="<%= members[0] ? members[0].name : '' %>">
              <input type="hidden" name="member_relationship" id="memberRel" value="<%= members[0] ? members[0].relationship : '' %>">
            <% } %>
          </div>
          <div style="height:1px;background:#f0f2f8;margin:0 0 20px;"></div>
          <!-- Document type -->
          <div style="margin-bottom:22px;">
            <div style="font-size:11px;font-weight:700;color:#9aa0b4;text-transform:uppercase;letter-spacing:.6px;margin-bottom:10px;display:flex;align-items:center;gap:6px;"><i class="fas fa-file-contract" style="color:#1d2448;"></i> Select Document Type</div>
            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;">
              <label style="border:2px solid #1d2448;border-radius:12px;padding:16px 12px;text-align:center;cursor:pointer;background:#1d2448;transition:all .2s;font-family:'Poppins',sans-serif;position:relative;" onclick="selectDoc(this)">
                <input type="radio" name="document_type" value="Barangay Clearance" checked style="display:none;">
                <div style="width:44px;height:44px;border-radius:50%;background:rgba(255,255,255,.15);color:#fff;display:flex;align-items:center;justify-content:center;font-size:18px;margin:0 auto 10px;"><i class="fas fa-certificate"></i></div>
                <div style="font-size:11.5px;font-weight:700;color:#fff;line-height:1.4;margin-bottom:4px;">Barangay Clearance</div>
                <div style="font-size:11px;color:rgba(255,255,255,.7);font-weight:600;">Free</div>
              </label>
              <label style="border:2px solid #e2e5ef;border-radius:12px;padding:16px 12px;text-align:center;cursor:pointer;background:#fff;transition:all .2s;font-family:'Poppins',sans-serif;position:relative;" onclick="selectDoc(this)">
                <input type="radio" name="document_type" value="Certificate of Residency" style="display:none;">
                <div style="width:44px;height:44px;border-radius:50%;background:#eef0fb;color:#1d2448;display:flex;align-items:center;justify-content:center;font-size:18px;margin:0 auto 10px;"><i class="fas fa-home"></i></div>
                <div style="font-size:11.5px;font-weight:700;color:#1a1d2e;line-height:1.4;margin-bottom:4px;">Certificate of Residency</div>
                <div style="font-size:11px;color:#9aa0b4;font-weight:600;">Free</div>
              </label>
              <label style="border:2px solid #e2e5ef;border-radius:12px;padding:16px 12px;text-align:center;cursor:pointer;background:#fff;transition:all .2s;font-family:'Poppins',sans-serif;position:relative;<%= isEmployed ? 'opacity:.6;pointer-events:none;border-color:#fad4d4;background:#fff5f5;' : '' %>" onclick="selectDoc(this)" id="indigencyCard">
                <input type="radio" name="document_type" value="Certificate of Indigency" style="display:none;" <%= isEmployed ? 'disabled' : '' %>>
                <div style="width:44px;height:44px;border-radius:50%;background:#eef0fb;color:#1d2448;display:flex;align-items:center;justify-content:center;font-size:18px;margin:0 auto 10px;"><i class="fas fa-hand-holding-heart"></i></div>
                <div style="font-size:11.5px;font-weight:700;color:#1a1d2e;line-height:1.4;margin-bottom:4px;">Certificate of Indigency</div>
                <div style="font-size:11px;color:#9aa0b4;font-weight:600;">Free</div>
                <% if (isEmployed) { %><div style="margin-top:6px;font-size:10px;font-weight:700;color:#c0392b;background:#fff0f1;border:1px solid #fad4d4;border-radius:6px;padding:3px 7px;display:inline-flex;align-items:center;gap:4px;"><i class="fas fa-ban"></i> Ineligible</div><% } %>
              </label>
            </div>
          </div>
          <div style="height:1px;background:#f0f2f8;margin:0 0 20px;"></div>
          <!-- Purpose -->
          <div style="margin-bottom:22px;">
            <div style="font-size:11px;font-weight:700;color:#9aa0b4;text-transform:uppercase;letter-spacing:.6px;margin-bottom:10px;display:flex;align-items:center;gap:6px;"><i class="fas fa-bullseye" style="color:#1d2448;"></i> Purpose</div>
            <select name="purpose" required style="width:100%;padding:11px 14px;border:2px solid #e2e5ef;border-radius:10px;font-size:13.5px;font-family:'Poppins',sans-serif;color:#1a1d2e;background:#fff;outline:none;box-sizing:border-box;">
              <option value="">-- Select Purpose --</option>
              <option>Employment</option>
              <option>School Enrollment</option>
              <option>Medical Assistance</option>
              <option>Business Permit</option>
              <option>Bank / Loan Application</option>
              <option>Travel / Passport</option>
              <option>Government Transaction</option>
              <option>Other</option>
            </select>
          </div>
          <!-- Notes -->
          <div style="margin-bottom:22px;">
            <div style="font-size:11px;font-weight:700;color:#9aa0b4;text-transform:uppercase;letter-spacing:.6px;margin-bottom:10px;display:flex;align-items:center;gap:6px;"><i class="fas fa-sticky-note" style="color:#1d2448;"></i> Additional Notes <span style="font-weight:400;text-transform:none;">(optional)</span></div>
            <textarea name="notes" placeholder="Any additional information..." style="width:100%;padding:11px 14px;border:2px solid #e2e5ef;border-radius:10px;font-size:13.5px;font-family:'Poppins',sans-serif;color:#1a1d2e;background:#fff;outline:none;resize:vertical;min-height:80px;box-sizing:border-box;"></textarea>
          </div>
          <button type="submit" style="width:100%;padding:13px;background:linear-gradient(135deg,#1d2448,#2e3a6e);color:#fff;border:none;border-radius:10px;font-size:14px;font-weight:700;font-family:'Poppins',sans-serif;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;"><i class="fas fa-paper-plane"></i> Submit Request</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    function filterRequests() {
      const q = document.getElementById('searchInput').value.toLowerCase();
      document.querySelectorAll('#requestsTable tbody tr').forEach(row => {
        row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
      });
    }
    function confirmCancel(id, docType) {
      document.getElementById('cancelDocType').textContent = docType;
      document.getElementById('cancelForm').action = '/resident/clearance/cancel/' + id;
      document.getElementById('cancelModal').classList.add('active');
    }
    function selectMember(label, name, rel) {
      document.querySelectorAll('#memberPills label').forEach(l => {
        l.style.background = '#fff'; l.style.borderColor = '#e2e5ef';
        l.querySelectorAll('div').forEach(d => { if(d.style) { d.style.color = ''; d.style.background = ''; } });
      });
      label.style.background = '#1d2448'; label.style.borderColor = '#1d2448';
      document.getElementById('forMember').value = name;
      document.getElementById('memberRel').value = rel;
    }
    function selectDoc(label) {
      document.querySelectorAll('[name="document_type"]').forEach(r => {
        const l = r.closest('label');
        if (l) { l.style.background = '#fff'; l.style.borderColor = '#e2e5ef'; l.querySelectorAll('div,span').forEach(d => { d.style.color = ''; }); }
      });
      label.style.background = '#1d2448'; label.style.borderColor = '#1d2448';
      label.querySelector('input[type="radio"]').checked = true;
    }
    document.querySelectorAll('.db-nav-item').forEach(i => i.addEventListener('click', () => document.getElementById('sidebar').classList.remove('open')));
  </script>
</body>
</html>
