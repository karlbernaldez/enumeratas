<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Notifications - Bacolod BIS</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
  <link rel="stylesheet" href="/style.css">
</head>
<body class="db-body">
  <% const role = 'resident'; const active = 'notif'; %>
  <%- include('../../partials/sidebar', { role, active }) %>
  <div class="db-main">
    <%- include('../../partials/topbar', { pageTitle: 'Notifications' }) %>
    <div class="db-content">
      <div style="text-align:center;padding:60px 20px;color:#9aa0b4;">
        <i class="fas fa-bell" style="font-size:40px;display:block;margin-bottom:12px;color:#d0d5e8;"></i>
        <p>No notifications yet.</p>
      </div>
    </div>
  </div>
  <script>document.querySelectorAll('.db-nav-item').forEach(i=>i.addEventListener('click',()=>document.getElementById('sidebar').classList.remove('open')));</script>
</body>
</html>
