<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Profile - Bacolod BIS</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
  <link rel="stylesheet" href="/style.css">
</head>
<body class="db-body">
  <% const role = 'resident'; const active = 'profile'; %>
  <%- include('../../partials/sidebar', { role, active }) %>
  <div class="db-main">
    <%- include('../../partials/topbar', { pageTitle: 'My Profile' }) %>
    <div class="db-content">
      <%- include('../../partials/flash') %>
      <div class="db-card" style="background:#fff;border:1px solid #e8ecf4;border-radius:14px;padding:28px;margin-bottom:24px;">
        <div style="display:flex;align-items:center;gap:20px;margin-bottom:24px;">
          <div style="width:72px;height:72px;border-radius:50%;background:#1d2448;color:#fff;font-size:28px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <%= user && user.full_name ? user.full_name[0].toUpperCase() : 'U' %>
          </div>
          <div>
            <h2 style="font-size:20px;font-weight:700;color:#1a1d2e;margin:0 0 4px;"><%= user ? user.full_name : '' %></h2>
            <span style="font-size:12px;font-weight:600;background:#eef0fb;color:#1d2448;padding:3px 10px;border-radius:100px;">Resident</span>
          </div>
        </div>
        <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:16px;">
          <div><div style="font-size:11px;font-weight:700;color:#9aa0b4;text-transform:uppercase;letter-spacing:.4px;margin-bottom:4px;">Username</div><div style="font-size:14px;color:#1a1d2e;"><%= user ? user.username : '—' %></div></div>
          <div><div style="font-size:11px;font-weight:700;color:#9aa0b4;text-transform:uppercase;letter-spacing:.4px;margin-bottom:4px;">Email</div><div style="font-size:14px;color:#1a1d2e;"><%= user ? user.email : '—' %></div></div>
          <div><div style="font-size:11px;font-weight:700;color:#9aa0b4;text-transform:uppercase;letter-spacing:.4px;margin-bottom:4px;">Household No.</div><div style="font-size:14px;color:#1a1d2e;"><%= user && user.household_no ? user.household_no : '—' %></div></div>
          <div><div style="font-size:11px;font-weight:700;color:#9aa0b4;text-transform:uppercase;letter-spacing:.4px;margin-bottom:4px;">Zone</div><div style="font-size:14px;color:#1a1d2e;"><%= household ? household.zone || '—' : '—' %></div></div>
        </div>
      </div>
      <% if (household) { %>
      <div class="db-card" style="background:#fff;border:1px solid #e8ecf4;border-radius:14px;padding:28px;">
        <h3 style="font-size:15px;font-weight:700;color:#1a1d2e;margin:0 0 16px;"><i class="fas fa-home" style="color:#1d2448;margin-right:8px;"></i>Household Information</h3>
        <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:16px;">
          <div><div style="font-size:11px;font-weight:700;color:#9aa0b4;text-transform:uppercase;letter-spacing:.4px;margin-bottom:4px;">Head of Family</div><div style="font-size:14px;color:#1a1d2e;"><%= household.first_name %> <%= household.last_name %></div></div>
          <div><div style="font-size:11px;font-weight:700;color:#9aa0b4;text-transform:uppercase;letter-spacing:.4px;margin-bottom:4px;">Address</div><div style="font-size:14px;color:#1a1d2e;"><%= household.address || household.zone || '—' %></div></div>
          <div><div style="font-size:11px;font-weight:700;color:#9aa0b4;text-transform:uppercase;letter-spacing:.4px;margin-bottom:4px;">Contact</div><div style="font-size:14px;color:#1a1d2e;"><%= household.contact_number || '—' %></div></div>
          <div><div style="font-size:11px;font-weight:700;color:#9aa0b4;text-transform:uppercase;letter-spacing:.4px;margin-bottom:4px;">Members</div><div style="font-size:14px;color:#1a1d2e;"><%= members ? members.length + 1 : 1 %> person(s)</div></div>
        </div>
      </div>
      <% } %>
    </div>
  </div>
  <script>document.querySelectorAll('.db-nav-item').forEach(i=>i.addEventListener('click',()=>document.getElementById('sidebar').classList.remove('open')));</script>
</body>
</html>
