<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= title || 'Server Error' %></title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <main style="max-width: 800px; margin: 80px auto; font-family: Arial, sans-serif;">
    <h1>500 - Server Error</h1>
    <p>Something went wrong while processing your request.</p>

    <% if (typeof error !== 'undefined' && error) { %>
      <pre style="background:#f5f5f5; padding:16px; border-radius:8px; white-space:pre-wrap;"><%= error %></pre>
    <% } %>

    <a href="/">Back to Home</a>
  </main>
</body>
</html>